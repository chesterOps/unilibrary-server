# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URL=mongodb+srv://<username>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────────────────
# Use a long, random string — e.g. openssl rand -base64 64
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d
# Cookie expiry in days (used when sending token as HttpOnly cookie)
JWT_COOKIE_EXPIRES_IN=7

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Model for chat completions
OPENAI_CHAT_MODEL=gpt-4o-mini
# Model for vector embeddings (used in semantic search + recommendations)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Cloudinary (cover image storage) ─────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── MEGA (file storage) ───────────────────────────────────────────────────────
MEGA_EMAIL=your_mega_email@example.com
MEGA_PASSWORD=your_mega_password

# ── CORS ──────────────────────────────────────────────────────────────────────
# Space-separated list of allowed frontend origins
FRONT_URL=http://localhost:5173 https://yourdomain.com
