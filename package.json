    "@types/jsonwebtoken": "^9.0.10",
    "@types/megajs": "^0.14.7",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.1.0",
    "@types/nodemailer": "^8.0.0",
    "@types/streamifier": "^0.1.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
