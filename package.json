{
  "name": "node-server",
  "version": "1.0.0",
  "description": "backend application template",
  "main": "index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dir/index.js",
